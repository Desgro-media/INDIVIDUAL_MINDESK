# Copy this file to `.env` on the EC2 host, next to docker-compose.prod.yml,
# and fill in real values. `.env` is git-ignored — never commit it.

# ─── Domain for HTTPS (Caddy) ────────────────────────────────────────────────
# No domain? Use sslip.io: take your EC2 Elastic IP, e.g. 3.15.20.100, and
# replace the dots with dashes: 3-15-20-100.sslip.io — it resolves to that IP
# automatically, so Caddy/Let's Encrypt can issue a real cert for it.
DOMAIN=REPLACE-WITH-YOUR-ELASTIC-IP-DASHED.sslip.io

# ─── Database ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
DB_PASSWORD=REPLACE_ME

# ─── JWT ────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=REPLACE_ME

# ─── App base URL ───────────────────────────────────────────────────────────
# Your Vercel frontend URL, e.g. https://individual-mindesk.vercel.app
# (You won't know this until after the first Vercel deploy — update and
# `docker compose -f docker-compose.prod.yml up -d` again once you do.)
APP_BASE_URL=https://REPLACE-WITH-YOUR-VERCEL-DOMAIN.vercel.app

# ─── CORS ───────────────────────────────────────────────────────────────────
# REQUIRED now that this is a paid product — leaving this blank falls back to
# "*" (any origin may call the API). Set this to your Vercel domain (same
# value as APP_BASE_URL, no trailing slash).
ALLOWED_ORIGINS=https://REPLACE-WITH-YOUR-VERCEL-DOMAIN.vercel.app

# ─── Superadmin (you) ───────────────────────────────────────────────────────
# Seeded automatically on first boot — see backend StartupInitializer. Use an
# email that is NOT already a practitioner account. Leave both blank to skip
# seeding (you won't have a superadmin dashboard until you set these and restart).
SUPERADMIN_EMAIL=REPLACE_ME
# Generate with: openssl rand -base64 24
SUPERADMIN_PASSWORD=REPLACE_ME
# Optional — comma-separated exact IPs or dotted prefixes allowed to reach
# /api/v1/superadmin/**, e.g. "203.0.113.7". Blank = no restriction.
SUPERADMIN_IP_ALLOWLIST=

# ─── Platform GPay/UPI (shown to tenants on the Subscription page) ──────────
# Your own UPI ID that clients pay ₹9,999/year to, e.g. you@okhdfcbank
PLATFORM_UPI_ID=
# Optional — a QR code image as a data URL (data:image/png;base64,...).
PLATFORM_UPI_QR_BASE64=

# ─── Optional integrations — leave blank to run without them ────────────────
RESEND_API_KEY=
MAIL_USERNAME=
MAIL_PASSWORD=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# https://<DOMAIN>/api/v1/calendar/callback
GOOGLE_REDIRECT_URI=
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=
